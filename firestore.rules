rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/profiles/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function hasRole(role) {
      let path = /databases/$(database)/documents/profiles/$(request.auth.uid);
      return isSignedIn() && exists(path) && get(path).data.role == role;
    }

    function isAdmin() {
      // Prioritize email check as it's static and doesn't require a read
      return (isSignedIn() && request.auth.token.email.lower() == 'hassanimhoma2019@gmail.com') || hasRole('admin');
    }

    function isEmployee() {
      return isAdmin() || hasRole('employee');
    }

    function isClient() {
      return isAdmin() || hasRole('client');
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Profiles collection
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Productions collection
    match /productions/{productionId} {
      allow read: if isEmployee();
      allow create: if isEmployee() && isValidId(productionId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Stocks collection
    match /stocks/{locationId} {
      allow read: if isSignedIn();
      allow write: if isEmployee();
    }

    // Sales collection
    match /sales/{saleId} {
      allow read: if isEmployee() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow create: if isEmployee() && isValidId(saleId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Orders collection (Client Self-Service)
    match /orders/{orderId} {
      allow read: if isEmployee() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow create: if (isEmployee() || isClient()) && isValidId(orderId);
      allow update: if isEmployee() || (isSignedIn() && resource.data.clientId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // Clients collection
    match /clients/{clientId} {
      allow read: if isEmployee() || (isSignedIn() && request.auth.uid == clientId);
      allow write: if isEmployee();
    }

    // StockLogs collection
    match /stockLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
