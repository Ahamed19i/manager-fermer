# --- CONSEILS DE CONFIGURATION DE PRODUCTION (POUR VERCEL) ---
# Copiez ce fichier sous le nom de '.env' localement pour tester.
# Sur Vercel, ajoutez ces variables d'environnement dans le panneau de configuration de votre projet.

# Optionnel: Clé API Gemini (si utilisée)
GEMINI_API_KEY=""

# URL de l'Application (gérée dynamiquement par Vercel / Cloud Run)
APP_URL=""

# variables de production Firebase (Permet de ne pas exposer firebase-applet-config.json sur Github)
# Ajoutez les valeurs réelles de votre console Firebase
VITE_FIREBASE_API_KEY="VOTRE_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="VOTRE_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="VOTRE_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="VOTRE_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="VOTRE_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="VOTRE_FIREBASE_APP_ID"
VITE_FIREBASE_DATABASE_ID="VOTRE_FIREBASE_DATABASE_ID"
